/* pages/stats/stats.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.stats-header {
  padding: 30rpx;
  background: white;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stats-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: white;
  border-radius: 15rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.recent-records {
  background: white;
  border-radius: 15rpx;
  padding: 30rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-date {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.activity {
  font-size: 26rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
