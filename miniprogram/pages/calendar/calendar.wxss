/* pages/calendar/calendar.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.calendar-header {
  text-align: center;
  padding: 30rpx;
  background: white;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
}

.month {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  background: white;
  padding: 30rpx;
  border-radius: 15rpx;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 0;
}

.day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  position: relative;
  font-size: 28rpx;
  color: #333;
}

.day.today {
  background: #4A90D9;
  color: white;
}

.day.checked {
  background: #667eea;
  color: white;
}

.day-mark {
  position: absolute;
  bottom: 8rpx;
  font-size: 20rpx;
}

.legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 40rpx;
  padding: 20rpx;
  background: white;
  border-radius: 15rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.legend-dot.checked {
  background: #667eea;
}

.legend-dot.today {
  background: #4A90D9;
}
