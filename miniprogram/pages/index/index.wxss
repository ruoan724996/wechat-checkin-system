/* pages/index/index.wxss */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid #4A90D9;
}

.user-info {
  flex: 1;
}

.nick-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.welcome {
  font-size: 28rpx;
  color: #666;
}

/* 登录按钮 */
.login-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
}

/* 签到区域 */
.checkin-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.checkin-card {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 30rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.activity-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.checkin-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.checkin-stats text {
  font-size: 26rpx;
  color: #667eea;
}

.checkin-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx;
  font-size: 30rpx;
  width: 100%;
}

.checkin-btn[disabled] {
  background: #ccc;
}

.no-activity {
  text-align: center;
  padding: 40rpx;
}

.no-activity text {
  display: block;
  color: #999;
  margin-bottom: 20rpx;
}

.go-activity-btn {
  background: #4A90D9;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 15rpx 40rpx;
  font-size: 28rpx;
}

/* 功能入口 */
.features {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.feature-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
}

.feature-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #333;
}
