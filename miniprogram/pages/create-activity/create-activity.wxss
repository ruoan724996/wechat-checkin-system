/* pages/create-activity/create-activity.wxss */
.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 15rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

.input,
.textarea,
.picker {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.textarea {
  height: 200rpx;
}

.picker {
  color: #333;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
}
